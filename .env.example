# ============================================================
#  PhytoNova AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ----------------------------------------------------------------
# Supabase (required for auth, database, and storage)
# ----------------------------------------------------------------
# Project URL found in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# "anon" public key found in: Supabase Dashboard → Settings → API → Project API keys
# This key is safe to expose in the client.
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ----------------------------------------------------------------
# Hugging Face Inference API (required for disease detection)
# ----------------------------------------------------------------
# Personal Access Token from https://huggingface.co/settings/tokens
# Scopes needed: inference
VITE_HF_API_TOKEN=

# Model used for plant disease classification.  
# Default is a fine-tuned DeiT vision transformer.
VITE_HF_MODEL=facebook/deit-base-distilled-patch16-224

# ----------------------------------------------------------------
# Application
# ----------------------------------------------------------------
# Human-readable name displayed in the UI.
VITE_APP_NAME=PhytoNova AI

# Canonical base URL used for Open Graph meta tags and OAuth redirects.
# Update this when you deploy to a custom domain.
VITE_APP_URL=https://your-vercel-app.vercel.app